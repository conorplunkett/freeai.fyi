# Betterbacks API — copy to .env (or export) and fill in.

# Postgres connection string (Neon/Supabase/RDS/local).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/betterbacks

# Stripe — use test-mode keys (sk_test_...) until launch.
# Dashboard -> Developers -> API keys
STRIPE_SECRET_KEY=sk_test_xxx
# Dashboard -> Developers -> Webhooks -> your endpoint -> Signing secret
# (locally: `stripe listen --forward-to localhost:8787/v1/webhooks/stripe` prints one)
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Where the marketing site lives (Checkout success/cancel + Connect return URLs).
SITE_URL=https://betterbacks.ai

# Secret for POST /v1/admin/payouts.
ADMIN_KEY=change-me

# Money knobs.
REVENUE_SHARE=0.9            # developers keep 90% — the better split
DAILY_IMPRESSION_CAP=5000    # per device per UTC day (~7h of serving)
PAYOUT_THRESHOLD_CENTS=1000  # $10 minimum payout

PORT=8787
