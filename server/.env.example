# FreeAI API — copy to .env (or export) and fill in.

# Postgres connection string (Neon/Supabase/RDS/local).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/freeai

# Stripe — use test-mode keys (sk_test_...) until launch.
# Dashboard -> Developers -> API keys
STRIPE_SECRET_KEY=sk_test_xxx
# Dashboard -> Developers -> Webhooks -> your endpoint -> Signing secret
# (locally: `stripe listen --forward-to localhost:8787/v1/webhooks/stripe` prints one)
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Where the marketing site lives (Checkout success/cancel + Connect return URLs).
SITE_URL=https://freeai.fyi

# Secret for the admin endpoints (payouts sweep, moderation, killswitch).
ADMIN_KEY=change-me

# Set to 1 to boot with ad serving disabled (killswitch on). Toggle at runtime
# with POST /v1/admin/killswitch {"serving": true|false}.
KILLSWITCH=0

# Money knobs.
REVENUE_SHARE=0.5            # user's cut, redeemable as Claude credits
DAILY_IMPRESSION_CAP=5000    # per device per UTC day (~7h of serving)
PAYOUT_THRESHOLD_CENTS=1000  # $10 minimum payout

PORT=8787
