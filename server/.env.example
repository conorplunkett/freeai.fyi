# FreeAI API — copy to .env (or export) and fill in.

# Postgres connection string (Neon/Supabase/RDS/local).
# Supabase: Dashboard -> Connect -> Session pooler URI (port 5432).
# TLS is auto-enabled for *.supabase.co/.com and *.neon.tech; for any other
# managed host that needs SSL, set DATABASE_SSL=1.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/freeai
# DATABASE_SSL=1

# Stripe — use test-mode keys (sk_test_...) until launch.
# Dashboard -> Developers -> API keys
STRIPE_SECRET_KEY=sk_test_xxx
# Dashboard -> Developers -> Webhooks -> your endpoint -> Signing secret
# (locally: `stripe listen --forward-to localhost:8787/v1/webhooks/stripe` prints one)
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Where the marketing site lives (Checkout success/cancel + Connect return URLs).
SITE_URL=https://freeai.fyi

# Secret for the admin endpoints (payouts sweep, moderation, killswitch).
ADMIN_KEY=change-me

# Set to 1 to boot with ad serving disabled (killswitch on). Toggle at runtime
# with POST /v1/admin/killswitch {"serving": true|false}.
KILLSWITCH=0

# Money knobs.
REVENUE_SHARE=0.5            # user's cut, redeemable as Claude credits
GROSS_CPM_CENTS=1200         # advertiser gross CPM in cents (defaults to $12)
DAILY_IMPRESSION_CAP=5000    # per device per UTC day (~7h of serving)
IP_DAILY_IMPRESSION_CAP=5000 # per source IP per UTC day (= one device's worth); 0 disables it
DAILY_CLICK_CAP=100          # verified (token) clicks per device per UTC day; clicks bill 50x
PAYOUT_THRESHOLD_CENTS=1000  # $10 minimum payout

PORT=8787

# Email — gift-card fulfillment + magic-link login.
# Provider is "console" (logs to stdout) in dev/CI; set "resend" in production.
MAIL_PROVIDER=console
# Resend API key (required when MAIL_PROVIDER=resend). resend.com -> API Keys
RESEND_API_KEY=
# From address for outbound mail (e.g. "FreeAI <no-reply@freeai.fyi>").
MAIL_FROM=
# Inbox that receives gift-card redemption orders for manual fulfillment.
# Defaults to the maintainer's personal inbox — set this for production.
GIFT_FULFILLMENT_EMAIL=

# Google OAuth — create at console.cloud.google.com -> APIs & Services -> Credentials
# Authorized redirect URI (local): http://localhost:8787/v1/auth/google/callback
# Production runs as the Edge Function: https://<ref>.supabase.co/functions/v1/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple Sign In — create at developer.apple.com -> Identifiers -> Services IDs
# Authorized redirect URI (local): http://localhost:8787/v1/auth/apple/callback
# Production runs as the Edge Function: https://<ref>.supabase.co/functions/v1/api/v1/auth/apple/callback
# APPLE_PRIVATE_KEY: paste the contents of the .p8 file with literal \n between lines
APPLE_CLIENT_ID=fyi.freeai.web
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
