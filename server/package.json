{
  "name": "freeai-server",
  "version": "0.1.0",
  "description": "FreeAI.fyi backend — ad auction, impression ledger, Stripe money in/out. Users keep 50%, redeemable as Claude credits.",
  "private": true,
  "main": "src/index.js",
  "scripts": {
    "start": "node --env-file-if-exists=.env src/index.js",
    "migrate": "node --env-file-if-exists=.env src/migrate.js",
    "seed": "node --env-file-if-exists=.env src/seed.js",
    "test": "node test/run.js",
    "payouts": "node -e \"require('./src/boot').boot().then(({deps}) => require('./src/payouts').runPayouts(deps)).then(r => {console.log(r); process.exit(0)})\""
  },
  "engines": {
    "node": ">=20.12.0"
  },
  "dependencies": {
    "pg": "^8.12.0"
  }
}
