{
  "manifest_version": 3,
  "name": "FreeAI.fyi — Earn from ChatGPT, Claude & Gemini",
  "version": "0.5.5",
  "description": "Earn money while you use AI. Ads appear while AI thinks — 50% of revenue goes to you.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "FreeAI — earnings",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "https://wpjfhezklpczxzocgxsb.supabase.co/*",
    "https://freeai.fyi/*",
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*"
      ],
      "js": ["src/ads.js", "src/content.js"],
      "css": ["src/inject.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://freeai.fyi/*"],
      "js": ["src/link.js"],
      "run_at": "document_idle"
    }
  ]
}
