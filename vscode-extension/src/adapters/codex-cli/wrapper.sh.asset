#!/bin/sh
# ===== FREEAI-CODEX-CLI =====
# Reversible FreeAI wrapper around the npm-installed codex shim.
# Prints a one-line ad banner read from "__FREEAI_AD_PATH__" then
# exec's the pristine shim at "__FREEAI_BACKUP__".
# Restore: copy that backup back over this file (or run freeai restore).
AD_FILE="__FREEAI_AD_PATH__"
AD_TEXT="Earning with FreeAI"
if [ -r "$AD_FILE" ]; then
  AD_TEXT=$(head -n 1 "$AD_FILE" 2>/dev/null || echo "Earning with FreeAI")
fi
printf '\n  [ad]  %s\n\n' "$AD_TEXT"
exec "__FREEAI_BACKUP__" "$@"
