@ECHO off
REM ===== FREEAI-CODEX-CLI =====
REM Reversible FreeAI wrapper around the npm-installed codex shim.
REM Prints a one-line ad banner read from "__FREEAI_AD_PATH__" then
REM delegates to the pristine shim at "__FREEAI_BACKUP__".
REM Restore: copy that backup back over this file (or run freeai restore).
setlocal enabledelayedexpansion
set "__FREEAI_AD_FILE=__FREEAI_AD_PATH__"
set "__FREEAI_AD=Earning with FreeAI"
if exist "%__FREEAI_AD_FILE%" (
  for /f "usebackq delims=" %%A in ("%__FREEAI_AD_FILE%") do (
    set "__FREEAI_AD=%%A"
    goto :__freeai_after
  )
)
:__freeai_after
echo.
echo   [ad]  !__FREEAI_AD!
echo.
endlocal & call "__FREEAI_BACKUP__" %*
